<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context="tun.proxy.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/status_card"
            style="@style/Widget.ProxSox.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot"
                    android:contentDescription="@string/status_indicator_desc" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/status_progress"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:visibility="gone"
                    app:indicatorColor="@color/colorWarning"
                    app:indicatorSize="16dp"
                    app:trackThickness="2dp" />

                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/status_disconnected"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_recheck_proxy"
                    style="@style/Widget.ProxSox.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp"
                    android:text="@string/btn_recheck"
                    android:textSize="12sp"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Active proxy section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.1"
            android:text="@string/active_proxy_label"
            android:textAllCaps="true"
            android:textColor="@color/colorOnBackground"
            android:textSize="12sp" />

        <!-- Active proxy tile -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/active_proxy_card"
            style="@style/Widget.ProxSox.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            app:rippleColor="#204FC3F7">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Filled state -->
                <LinearLayout
                    android:id="@+id/active_filled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/active_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/colorOnSurface"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Home server" />

                            <TextView
                                android:id="@+id/active_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_type_badge"
                                android:textAllCaps="true"
                                android:textColor="@color/colorSecondary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                tools:text="SOCKS5" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/active_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/colorOnBackground"
                            android:textSize="13sp"
                            tools:text="socks5://***@1.2.3.4:1080" />

                        <TextView
                            android:id="@+id/active_meta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/colorSecondary"
                            android:textSize="11sp"
                            tools:text="Remote DNS · on" />

                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_active_more"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_more"
                        android:src="@drawable/ic_more_vert" />

                </LinearLayout>

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/active_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/active_empty_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/active_proxy_none_title"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/active_proxy_none_subtitle"
                        android:textColor="@color/colorOnBackground"
                        android:textSize="13sp" />

                </LinearLayout>

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Action row: New / Saved -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new"
                style="@style/Widget.ProxSox.ToggleButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/btn_new"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="@color/colorSecondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_load"
                style="@style/Widget.ProxSox.ToggleButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/btn_saved"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="@color/colorSecondary" />

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="24dp" />

        <!-- Connect Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/start"
            style="@style/Widget.ProxSox.Button.Connect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_connect" />

        <!-- Disconnect Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/stop"
            style="@style/Widget.ProxSox.Button.Disconnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_disconnect"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
